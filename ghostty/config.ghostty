# Updates
auto-update = check
auto-update-channel = stable

# Theme
theme = dark:frappe-custom,light:Catppuccin Latte

# Font
font-family = JetBrains Mono
font-size = 12
font-thicken = true

# Window
window-padding-x = 12
window-padding-y = 12

# macOS titlebar & icon
macos-icon = blueprint
macos-titlebar-proxy-icon = hidden
title = " "
window-title-font-family = JetBrains Mono

# Keybindings
# Claude Code: send ESC+CR on Shift+Enter so it's distinguishable from plain
# Enter (newline vs. submit). Raw bytes pass through tmux untouched, rather than
# relying on the kitty-protocol path.
keybind = shift+enter=text:\x1b\r
